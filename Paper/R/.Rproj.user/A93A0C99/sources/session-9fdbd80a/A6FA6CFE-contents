#   compute entropy for region_final which can take values like mouth, eyes and other
# both statiponary and transotio entropy

library(dplyr)

# helpers
library(dplyr)

regions_all <- cluster_results_labelled %>%
  distinct(region_final) %>%
  arrange(region_final) %>%
  pull(region_final)

shannon_entropy <- function(p){
  p <- p[p > 0]
  -sum(p * log2(p))
}

stationary_entropy <- function(df, alpha = 0){
  df <- as.data.frame(df)
  counts <- table(factor(df$region_final, levels = regions_all))
  counts_sm <- counts + alpha
  probs <- counts_sm / sum(counts_sm)
  shannon_entropy(probs)
}

transition_entropy <- function(df, order_col, alpha = 0){
  df <- as.data.frame(df)

  # order safely (base R)
  o <- order(df[[order_col]])
  df <- df[o, , drop = FALSE]

  # build next state
  next_region <- df$region_final[-1]
  curr_region <- df$region_final[-nrow(df)]

  if (length(curr_region) == 0) return(NA_real_)

  # full KxK counts over the fixed state space
  C <- table(
    factor(curr_region, levels = regions_all),
    factor(next_region, levels = regions_all)
  )

  # add-alpha smoothing (alpha=1 makes every transition possible)
  C_sm <- C + alpha

  out_sm <- rowSums(C_sm)
  pi_sm  <- out_sm / sum(out_sm)

  P_sm <- sweep(C_sm, 1, out_sm, "/")

  H_rows <- apply(P_sm, 1, shannon_entropy)

  sum(pi_sm * H_rows)
}

aoi_clust_entropy_results <- cluster_results_labelled %>%
  group_by(ssid_bris_birm, stimnopath) %>%
  summarise(
    stat_entropy  = stationary_entropy(pick(everything()), alpha = 1),
    trans_entropy = transition_entropy(pick(everything()), order_col = "order", alpha = 1),
    .groups = "drop"
  )

aoi_clust_entropy_results%>%
  ggplot(aes(stat_entropy,trans_entropy))+
  geom_point()
