```{r}
# Relabel clusters per stimulus based on centroid y position
# Lower y value = higher on screen = eyes
# Higher y value = lower on screen = mouth

cluster_labels <- cluster_results_k2 %>%
  group_by(stimnopath, cluster) %>%
  summarise(
    cx = mean(mean_x),
    cy = mean(mean_y),
    .groups = "drop"
  ) %>%
  group_by(stimnopath) %>%
  arrange(cy, .by_group = TRUE) %>%  # sort ascending by y within each stimulus
  mutate(
    region = case_when(
      row_number() == 1 ~ "eyes",   # lowest y = highest on screen = eyes
      row_number() == 2 ~ "mouth",  # highest y = lowest on screen = mouth
      TRUE ~ "other"                # if k=3, third cluster
    )
  ) %>%
  ungroup() %>%
  select(stimnopath, cluster, region, cx, cy)

# Quick sanity check - look at a few to confirm
cluster_labels %>%
  group_by(stimnopath) %>%
  arrange(stimnopath, cy) %>%
  head(20)

# Visual check - plot centroid positions coloured by assigned label
cluster_labels %>%
  ggplot(aes(x = cx, y = cy, colour = region)) +
  geom_point(alpha = 0.6, size = 2) +
  scale_y_reverse() +
  labs(
    title = "Centroid positions by assigned region across all stimuli",
    subtitle = "Eyes should consistently sit above mouth on screen",
    x = "Centroid X", y = "Centroid Y"
  ) +
  theme_minimal()
```

```{r}
# Keep cluster_labels as just the mapping - no centroid columns
cluster_labels_clean <- cluster_labels %>%
  select(stimnopath, cluster, region)

# Step 1: Compute per-stimulus, per-region centroids separately
centroids <- cluster_results_k2 %>%
  left_join(cluster_labels_clean, by = c("stimnopath", "cluster")) %>%
  group_by(stimnopath, region) %>%
  summarise(
    cx = mean(mean_x), 
    cy = mean(mean_y), 
    .groups = "drop"
  )

# Step 2: Join region labels first, then centroids separately
cluster_results_labelled <- cluster_results_k2 %>%
  left_join(cluster_labels_clean, by = c("stimnopath", "cluster")) %>%
  left_join(centroids, by = c("stimnopath", "region")) %>%
  mutate(
    euclid_dist = sqrt((mean_x - cx)^2 + (mean_y - cy)^2)
  )

# Quick check - should have no NAs in euclid_dist
cluster_results_labelled %>%
  summarise(
    n_total = n(),
    n_na_cx = sum(is.na(cx)),
    n_na_cy = sum(is.na(cy)),
    n_na_dist = sum(is.na(euclid_dist))
  )

# Step 3: Compute threshold PER STIMULUS PER REGION
# This way each cluster gets its own radius based on its own spread
threshold_vals_per_stim <- cluster_results_labelled %>%
  group_by(stimnopath, region) %>%
  summarise(
    threshold_r = 2 * median(euclid_dist, na.rm = TRUE),
    .groups = "drop"
  )

# Inspect the distribution of per-stimulus thresholds
threshold_vals_per_stim %>%
  ggplot(aes(x = threshold_r, fill = region)) +
  geom_histogram(bins = 20, alpha = 0.7) +
  facet_wrap(~region) +
  labs(title = "Distribution of per-stimulus threshold radii",
       x = "Threshold radius (pixels)")

# Step 4: Apply per-stimulus threshold
cluster_results_labelled <- cluster_results_labelled %>%
  left_join(threshold_vals_per_stim, by = c("stimnopath", "region")) %>%
  mutate(
    region_final = if_else(euclid_dist <= threshold_r, region, "other")
  )

# Step 5: Check retention overall and per stimulus
cluster_results_labelled %>%
  count(region_final) %>%
  mutate(prop = n / sum(n))

# Per stimulus retention - flag any stimuli with very low retention
cluster_results_labelled %>%
  group_by(stimnopath) %>%
  summarise(
    prop_eyes = mean(region_final == "eyes"),
    prop_mouth = mean(region_final == "mouth"),
    prop_other = mean(region_final == "other"),
    .groups = "drop"
  ) %>%
  arrange(desc(prop_other))

# Step 6: Regenerate circles using per-stimulus thresholds
circles <- centroids %>%
  filter(region != "other") %>%
  left_join(threshold_vals_per_stim, by = c("stimnopath", "region")) %>%
  rowwise() %>%
  mutate(circle = list(make_circle(cx, cy, threshold_r))) %>%
  unnest(circle)

# Step 7: Replot
stim_subset <- unique(cluster_results_labelled$stimnopath)[1:6]

cluster_results_labelled %>%
  filter(stimnopath %in% stim_subset) %>%
  ggplot(aes(mean_x, mean_y, colour = region_final)) +
  geom_point(alpha = 0.3, size = 0.8) +
  geom_path(
    data = circles %>% filter(stimnopath %in% stim_subset),
    aes(mean_x, mean_y, group = interaction(stimnopath, region)),
    colour = "black", linewidth = 0.4, linetype = "dashed",
    inherit.aes = FALSE
  ) +
  geom_point(
    data = centroids %>% filter(stimnopath %in% stim_subset,
                                 region != "other"),
    aes(cx, cy),
    colour = "black", shape = 3, size = 4, stroke = 0.5,
    inherit.aes = FALSE
  ) +
  scale_y_reverse() +
  facet_wrap(~stimnopath) +
  coord_fixed() +
  scale_colour_manual(values = c("eyes"  = "#F8766D",
                                  "mouth" = "#00BFC4",
                                  "other" = "grey70")) +
  labs(
    title = "Per-stimulus circular boundaries",
    subtitle = "Threshold = 2 × median Euclidean distance within each stimulus-region",
    colour = "Region",
    x = "X (pixels)", y = "Y (pixels)"
  ) +
  theme_minimal() +
  theme(strip.text = element_text(size = 7))
```

