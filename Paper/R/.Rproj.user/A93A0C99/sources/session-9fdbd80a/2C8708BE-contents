)

# Mouth
lmm_results_corrected$mouth_accuracy <- lmer(
  prop_fix_dur ~ dplf_bin_fake_accuracy * emotion_yes_no_new +
    (1|ssid_bris_birm) + (1|stimnopath),
  REML = FALSE,
  data = aoi_summary_clean_corrected %>% filter(region_final == "mouth")
)

lmm_results_corrected$mouth_groundtruth <- lmer(
  prop_fix_dur ~ isfake_or_real * emotion_yes_no_new +
    (1|ssid_bris_birm) + (1|stimnopath),
  REML = FALSE,
  data = aoi_summary_clean_corrected %>% filter(region_final == "mouth")
)

lmm_results_corrected$mouth_response <- lmer(
  prop_fix_dur ~ dplf_bin_fake_1_real_0 * emotion_yes_no_new +
    (1|ssid_bris_birm) + (1|stimnopath),
  REML = FALSE,
  data = aoi_summary_clean_corrected %>% filter(region_final == "mouth")
)

lapply(lmm_results_corrected, anova)
```

None of the predictors are significant.

Accuracy doesn't predict fixation duration to eyes or mouth in any model.

Ground truth doesn't predict fixation to either region.

Participant response doesn't predict fixation to either region.

None of the interactions with emotion are significant.

The only effect that is significant is a main effect of emotion on eye fixation duration (p = .046), meaning people spend slightly more time looking at the eye region during emotive videos generally, but this is independent of whether they are correct, real vs fake, or their response. General attention effect.

```{r}
# Compute eye/mouth ratio per participant per trial
aoi_ratio <- aoi_summary_clean %>%
  select(ssid_bris_birm, stimnopath, region_final, 
