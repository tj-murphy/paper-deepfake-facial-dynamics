There are 11 stimuli that are in the raw data but not in the aggregated data. This doesn't matter too much because the main 40 videos are fine. I can remove these 11 and continue.

```{r}
# Filter to only the 40 matched stimuli
# Corrected aggregation
# Stimulus duration is 10 seconds = 10000ms
STIM_DURATION_MS <- 10000

aoi_summary_clean_corrected <- cluster_results_labelled %>%
  # Filter to matched stimuli only
  filter(stimnopath %in% unique(aoi_summary_clean$stimnopath)) %>%
  filter(region_final %in% c("eyes", "mouth")) %>%
  group_by(ssid_bris_birm, stimnopath, region_final) %>%
  summarise(
    # Mean fixation duration per fixation event (should be ~200-400ms)
    mean_fix_dur = mean(duration, na.rm = TRUE),
    # Sum of fixation duration normalised by stimulus duration
    prop_fix_dur = sum(duration, na.rm = TRUE) / STIM_DURATION_MS,
    n_fixations = n(),
    .groups = "drop"
  ) %>%
  left_join(
    dta_gaze_aggregated %>%
      select(ssid_bris_birm, stimnopath, text, trial,
             isfake_or_real,
             dplf_bin_fake_1_real_0,
             dplf_bin_fake_accuracy,
             emotion_yes_no_new),
