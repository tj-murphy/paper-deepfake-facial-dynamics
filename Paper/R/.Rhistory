library(tidyverse)
library(dplyr)
library(lmerTest)
dta_gaze_aggregated <- read_csv("../../../Data/Paper 1/dta_dfplf_bris_23_24_birm_22_23_eytrk_behav_quest1_PLD(in).csv")
dta_gaze_raw <- readRDS("../../../Data/Paper 1/dta_df_plfstim_gp_all_fix_stim_only1.rds")
colnames(dta_gaze_raw)
colnames(dta_gaze_aggregated)
fix_data <- dta_gaze_raw %>% filter(value == "f")
cluster_results_k2 <- fix_data %>%
group_by(stimnopath) %>%
group_modify(~ {
coords <- .x %>% select(mean_x, mean_y)
km <- kmeans(coords, centers = 2, nstart = 25)
.x %>% mutate(cluster = factor(km$cluster))
}) %>%
ungroup()
cluster_results_k2 %>%
filter(stimnopath %in% unique(stimnopath)[1:6]) %>%
ggplot(aes(mean_x, mean_y, colour = cluster)) +
geom_point(alpha = 0.3) +
scale_y_reverse() +
facet_wrap(~stimnopath) +
coord_fixed()
cluster_results_k2 %>%
ggplot(aes(mean_x, mean_y, colour = cluster)) +
geom_point(alpha = 0.2, size = 0.5) +
scale_y_reverse() +
facet_wrap(~stimnopath, ncol = 8) +
coord_fixed() +
theme(strip.text = element_text(size = 5))
cluster_labels <- cluster_results_k2 %>%
group_by(stimnopath, cluster) %>%
summarise(
cx = mean(mean_x),
cy = mean(mean_y),
.groups = "drop"
) %>%
group_by(stimnopath) %>%
arrange(cy, .by_group = TRUE) %>%
mutate(
region = case_when(
row_number() == 1 ~ "eyes",
row_number() == 2 ~ "mouth",
TRUE ~ "other"
)
) %>%
ungroup() %>%
select(stimnopath, cluster, region, cx, cy)
# Sanity check
cluster_labels %>%
ggplot(aes(x = cx, y = cy, colour = region)) +
geom_point(alpha = 0.6, size = 2) +
scale_y_reverse() +
labs(title = "Centroid positions by assigned region across all stimuli",
x = "Centroid X", y = "Centroid Y") +
theme_minimal()
cluster_labels_clean <- cluster_labels %>%
select(stimnopath, cluster, region)
centroids <- cluster_results_k2 %>%
left_join(cluster_labels_clean, by = c("stimnopath", "cluster")) %>%
group_by(stimnopath, region) %>%
summarise(cx = mean(mean_x), cy = mean(mean_y), .groups = "drop")
cluster_results_labelled <- cluster_results_k2 %>%
left_join(cluster_labels_clean, by = c("stimnopath", "cluster")) %>%
left_join(centroids, by = c("stimnopath", "region")) %>%
mutate(euclid_dist = sqrt((mean_x - cx)^2 + (mean_y - cy)^2))
# Per-stimulus per-region threshold: 2 × median Euclidean distance
threshold_vals_per_stim <- cluster_results_labelled %>%
group_by(stimnopath, region) %>%
summarise(threshold_r = 2 * median(euclid_dist, na.rm = TRUE), .groups = "drop")
cluster_results_labelled <- cluster_results_labelled %>%
left_join(threshold_vals_per_stim, by = c("stimnopath", "region")) %>%
mutate(region_final = if_else(euclid_dist <= threshold_r, region, "other"))
# Retention check
cluster_results_labelled %>%
count(region_final) %>%
mutate(prop = n / sum(n))
cluster_results_labelled %>%
filter(stimnopath %in% unique(stimnopath)[1:6]) %>%
ggplot(aes(mean_x, mean_y, colour = region_final)) +
geom_point(alpha = 0.4) +
scale_y_reverse() +
facet_wrap(~stimnopath) +
coord_fixed() +
scale_colour_manual(values = c("eyes" = "#F8766D", "mouth" = "#00BFC4", "other" = "grey70")) +
labs(title = "Fixations labelled by region after threshold", colour = "Region")
cluster_results_labelled %>%
ggplot(aes(mean_x, mean_y, colour = region_final)) +
geom_point(alpha = 0.2, size = 0.5) +
scale_y_reverse() +
facet_wrap(~stimnopath, ncol = 8) +
coord_fixed() +
scale_colour_manual(values = c("eyes" = "#F8766D", "mouth" = "#00BFC4", "other" = "grey70")) +
theme(strip.text = element_text(size = 5)) +
labs(title = "All stimuli: fixation regions after threshold")
stim_raw <- unique(cluster_results_labelled$stimnopath)
stim_agg <- unique(dta_gaze_aggregated$stimnopath)
cat("Matched:", sum(stim_raw %in% stim_agg), "\n")
cat("Unmatched:", sum(!stim_raw %in% stim_agg), "\n")
# Keep only matched stimuli
matched_stimuli <- intersect(stim_raw, stim_agg)
# Define thresholds
TRIAL_VALIDITY_THRESHOLD <- 0.50   # exclude trials with <50% valid gaze samples
PPT_VALIDITY_THRESHOLD   <- 0.50   # exclude participants with <50% overall validity
# Get validity metrics from aggregated data
validity_info <- dta_gaze_aggregated %>%
select(ssid_bris_birm, stimnopath, gaze_valid_prop, gaze_valid_prop_ppt) %>%
distinct()
# Inspect validity distributions before filtering
cat("--- Trial-level validity ---\n")
summary(validity_info$gaze_valid_prop)
cat("\n--- Participant-level validity ---\n")
validity_info %>%
distinct(ssid_bris_birm, gaze_valid_prop_ppt) %>%
pull(gaze_valid_prop_ppt) %>%
summary()
# Visualise validity distributions
validity_info %>%
ggplot(aes(x = gaze_valid_prop)) +
geom_histogram(bins = 50, fill = "steelblue", alpha = 0.7) +
geom_vline(xintercept = TRIAL_VALIDITY_THRESHOLD, linetype = "dashed", colour = "red") +
labs(title = "Trial-level gaze validity distribution",
subtitle = paste0("Red line = exclusion threshold (", TRIAL_VALIDITY_THRESHOLD * 100, "%)"),
x = "Proportion valid gaze samples", y = "Count") +
theme_minimal()
validity_info %>%
distinct(ssid_bris_birm, gaze_valid_prop_ppt) %>%
ggplot(aes(x = gaze_valid_prop_ppt)) +
geom_histogram(bins = 30, fill = "darkorange", alpha = 0.7) +
geom_vline(xintercept = PPT_VALIDITY_THRESHOLD, linetype = "dashed", colour = "red") +
labs(title = "Participant-level gaze validity distribution",
subtitle = paste0("Red line = exclusion threshold (", PPT_VALIDITY_THRESHOLD * 100, "%)"),
x = "Proportion valid gaze samples", y = "Count") +
theme_minimal()
# identify valid participants and trials
valid_participants <- validity_info %>%
distinct(ssid_bris_birm, gaze_valid_prop_ppt) %>%
filter(gaze_valid_prop_ppt >= PPT_VALIDITY_THRESHOLD) %>%
pull(ssid_bris_birm)
valid_trials <- validity_info %>%
filter(gaze_valid_prop >= TRIAL_VALIDITY_THRESHOLD) %>%
select(ssid_bris_birm, stimnopath)
cat("\nParticipants before filter:", n_distinct(validity_info$ssid_bris_birm), "\n")
cat("Participants after filter:", length(valid_participants), "\n")
cat("Trials before filter:", nrow(validity_info), "\n")
cat("Trials after filter:", nrow(valid_trials), "\n")
STIM_DURATION_MS <- 10000
# aggregate fixation data from labelled clusters (matched + quality-filtered)
aoi_observed <- cluster_results_labelled %>%
filter(stimnopath %in% matched_stimuli) %>%
# apply quality filters
filter(ssid_bris_birm %in% valid_participants) %>%
semi_join(valid_trials, by = c("ssid_bris_birm", "stimnopath")) %>%
group_by(ssid_bris_birm, stimnopath, region_final) %>%
summarise(
mean_fix_dur = mean(duration, na.rm = TRUE),
total_fix_dur = sum(duration, na.rm = TRUE),
prop_fix_dur = sum(duration, na.rm = TRUE) / STIM_DURATION_MS,
n_fixations = n(),
.groups = "drop"
)
# build complete grid of participant × stimulus × region
# all three AOIs must appear for every participant-stimulus combo
all_ppt_stim <- aoi_observed %>%
distinct(ssid_bris_birm, stimnopath)
aoi_levels <- c("eyes", "mouth", "other")
complete_grid <- all_ppt_stim %>%
crossing(region_final = aoi_levels)
# join observed data onto complete grid, fill missing with zeros
aoi_complete <- complete_grid %>%
left_join(aoi_observed, by = c("ssid_bris_birm", "stimnopath", "region_final")) %>%
mutate(
mean_fix_dur  = replace_na(mean_fix_dur, 0),
total_fix_dur = replace_na(total_fix_dur, 0),
prop_fix_dur  = replace_na(prop_fix_dur, 0),
n_fixations   = replace_na(n_fixations, 0L)
)
# verify
cat("Rows in complete AOI matrix:", nrow(aoi_complete), "\n")
cat("Expected (ppts × stimuli × 3 AOIs):",
nrow(all_ppt_stim) * 3, "\n")
# every participant-stimulus has exactly 3 rows
aoi_complete %>%
count(ssid_bris_birm, stimnopath) %>%
pull(n) %>%
table()
aoi_complete <- aoi_complete %>%
left_join(
dta_gaze_aggregated %>%
select(ssid_bris_birm, stimnopath,
isfake_or_real,
dplf_bin_fake_1_real_0,
dplf_bin_fake_accuracy,
emotion_yes_no_new,
gaze_valid_prop,
gaze_valid_prop_ppt),
by = c("ssid_bris_birm", "stimnopath")
) %>%
filter(!is.na(dplf_bin_fake_accuracy),
!is.na(emotion_yes_no_new))
# sanity checks
cat("Final dataset rows:", nrow(aoi_complete), "\n")
cat("Participants:", n_distinct(aoi_complete$ssid_bris_birm), "\n")
cat("Stimuli:", n_distinct(aoi_complete$stimnopath), "\n")
aoi_complete %>%
group_by(region_final) %>%
summarise(
mean_fix_dur = mean(mean_fix_dur, na.rm = TRUE),
mean_prop = mean(prop_fix_dur, na.rm = TRUE),
prop_zero = mean(total_fix_dur == 0),
.groups = "drop"
)
regions_all <- c("eyes", "mouth", "other")
shannon_entropy <- function(p) {
p <- p[p > 0]
-sum(p * log2(p))
}
stationary_entropy <- function(df, alpha = 0) {
df <- as.data.frame(df)
counts <- table(factor(df$region_final, levels = regions_all))
counts_sm <- counts + alpha
probs <- counts_sm / sum(counts_sm)
shannon_entropy(probs)
}
transition_entropy <- function(df, order_col, alpha = 0) {
df <- as.data.frame(df)
o <- order(df[[order_col]])
df <- df[o, , drop = FALSE]
next_region <- df$region_final[-1]
curr_region <- df$region_final[-nrow(df)]
if (length(curr_region) == 0) return(NA_real_)
C <- table(
factor(curr_region, levels = regions_all),
factor(next_region, levels = regions_all)
)
C_sm <- C + alpha
out_sm <- rowSums(C_sm)
pi_sm <- out_sm / sum(out_sm)
P_sm <- sweep(C_sm, 1, out_sm, "/")
H_rows <- apply(P_sm, 1, shannon_entropy)
sum(pi_sm * H_rows)
}
# compute on quality-filtered, matched raw data
aoi_clust_entropy_results <- cluster_results_labelled %>%
filter(stimnopath %in% matched_stimuli) %>%
filter(ssid_bris_birm %in% valid_participants) %>%
semi_join(valid_trials, by = c("ssid_bris_birm", "stimnopath")) %>%
group_by(ssid_bris_birm, stimnopath) %>%
summarise(
stat_entropy  = stationary_entropy(pick(everything()), alpha = 1),
trans_entropy = transition_entropy(pick(everything()), order_col = "order", alpha = 1),
.groups = "drop"
)
# scatterplot of entropy measures
aoi_clust_entropy_results %>%
ggplot(aes(stat_entropy, trans_entropy)) +
geom_point(alpha = 0.3) +
labs(title = "Stationary vs Transition Entropy (AOI-based)",
x = "Stationary Entropy", y = "Transition Entropy") +
theme_minimal()
# join entropy to complete AOI dataset
aoi_complete <- aoi_complete %>%
left_join(aoi_clust_entropy_results, by = c("ssid_bris_birm", "stimnopath"))
aoi_complete <- aoi_complete %>%
mutate(
log_mean_fix_dur = log1p(mean_fix_dur),
log_prop_fix_dur = log1p(prop_fix_dur)
)
# visualise distributions before and after log transform
aoi_complete %>%
filter(region_final != "other") %>%
pivot_longer(cols = c(prop_fix_dur, log_prop_fix_dur),
names_to = "transform", values_to = "value") %>%
ggplot(aes(x = value, fill = region_final)) +
geom_histogram(bins = 50, alpha = 0.7, position = "identity") +
facet_grid(transform ~ region_final, scales = "free") +
labs(title = "Distribution of fixation proportion: raw vs log-transformed") +
theme_minimal()
