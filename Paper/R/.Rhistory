# Ground truth × Emotion × Region
lmm_results$cross_groundtruth_prop <- lmer(
log_prop_fix_dur ~ isfake_or_real * emotion_yes_no_new * region_final +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
data = aoi_eyes_mouth
)
# Response × Emotion × Region
lmm_results$cross_response_prop <- lmer(
log_prop_fix_dur ~ dplf_bin_fake_1_real_0 * emotion_yes_no_new * region_final +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
data = aoi_eyes_mouth
)
# Same with mean fixation duration
lmm_results$cross_accuracy_fixdur <- lmer(
log_mean_fix_dur ~ dplf_bin_fake_accuracy * emotion_yes_no_new * region_final +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
data = aoi_eyes_mouth
)
lmm_results$cross_groundtruth_fixdur <- lmer(
log_mean_fix_dur ~ isfake_or_real * emotion_yes_no_new * region_final +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
data = aoi_eyes_mouth
)
lmm_results$cross_response_fixdur <- lmer(
log_mean_fix_dur ~ dplf_bin_fake_1_real_0 * emotion_yes_no_new * region_final +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
data = aoi_eyes_mouth
)
cat("=== Cross-AOI LMM Results ===\n\n")
cross_models <- grep("^cross_", names(lmm_results), value = TRUE)
lapply(cross_models, function(nm) {
cat(paste0("--- ", nm, " ---\n"))
print(anova(lmm_results[[nm]]))
cat("\n")
})
# Use one row per participant-stimulus for entropy (not per-AOI)
entropy_data <- aoi_complete %>%
distinct(ssid_bris_birm, stimnopath, .keep_all = TRUE) %>%
filter(!is.na(stat_entropy), !is.na(trans_entropy))
lmm_results$entropy_stat_accuracy <- lmer(
stat_entropy ~ dplf_bin_fake_accuracy * emotion_yes_no_new +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
data = entropy_data
)
lmm_results$entropy_trans_accuracy <- lmer(
trans_entropy ~ dplf_bin_fake_accuracy * emotion_yes_no_new +
(1 | ssid_bris_birm) + (1 | stimnopath),
REML = FALSE,
